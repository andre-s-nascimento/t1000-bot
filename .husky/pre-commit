#!/bin/sh

echo "🔍 Verificando arquivos proibidos..."

# Bloquear .env
if git diff --cached --name-only | grep -E '(^|/)\.env'; then
  echo "❌ ERRO: .env não pode ser commitado!"
  exit 1
fi

# Bloquear script sensível
if git diff --cached --name-only | grep -E 'obter-refresh-token\.sh'; then
  echo "❌ ERRO: Script com credenciais detectado!"
  exit 1
fi

# Detectar secrets reais (ignorando placeholders e exemplos com ...)
if git diff --cached | grep -E '(CLIENT_SECRET|API_KEY|PRIVATE_KEY|TOKEN)=.{10,}' | grep -v -E '\$\{|\.\.\.'; then
  echo "❌ ERRO: Possível secret REAL detectado!"
  exit 1
fi

echo "🧹 Rodando lint-staged..."
npx lint-staged

echo "✅ Commit seguro"